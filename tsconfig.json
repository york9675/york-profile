{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": [
    "src/**/*",
    "src/env.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "old"
  ]
}