---
import { inject } from '@vercel/analytics';
import SpeedInsights from '@vercel/speed-insights/astro';
import { appInfo } from '../data/app';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;

// Configuration for Vercel Toolbar
const toolbarProjectId = 'prj_bRdDHFkFdH7YZmPcbWgSgB7bA38U';
const toolbarOwnerId = 'team_lO4dEQU7946C21LoJmzJTUP7';
const toolbarBranch = import.meta.env.VERCEL_GIT_COMMIT_REF ?? 'main';

inject();
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <script is:inline>
      try {
        const mode = localStorage.getItem('themeMode') || 'dark';
        if (mode === 'system') {
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } else if (mode === 'light' || mode === 'newspaper') {
          document.documentElement.setAttribute('data-theme', mode);
        }
      } catch {}
    </script>
    <SpeedInsights />
    <slot name="head" />
  </head>
  <body>
    <slot />
    {appInfo.appEnv === 'development' && (
      <script
        is:inline
        src="https://vercel.live/_next-live/feedback/feedback.js"
        data-explicit-opt-in="true"
        data-owner-id={toolbarOwnerId}
        data-project-id={toolbarProjectId}
        data-branch={toolbarBranch}
      ></script>
    )}
  </body>
</html>
