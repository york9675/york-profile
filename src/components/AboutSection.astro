---
import AboutSectionIsland from './islands/AboutSectionIsland';
import { profileLinks } from '../data/config';
import type { UiStrings } from '../i18n/ui';

interface Props {
  t: UiStrings['about'];
}

const { t } = Astro.props;
const projectParts = t.tech.projectsTemplate.split(/\{(github|yorkDevelopment)\}/g);
const aviationParts = t.aviation.simTemplate.split(/\{(volanta)\}/g);
---

<section id="about" class="panel" aria-labelledby="about-heading">
  <h3 class="section-title" id="about-heading">{t.heading}</h3>
  <div class="body-text">
    <div class="about-summary">
      <p>{t.summary}</p>
    </div>

    <div class="interest-block">
      <h4 class="interest-title">{t.interestsHeading}</h4>
      <div class="interest-tabs" role="tablist" aria-label={t.tabsLabel}>
        <button type="button" class="interest-tab is-active" role="tab" aria-selected="true" aria-controls="panel-tech" id="interest-tech" tabindex="0" data-interest-tab><i class="fas fa-laptop-code" aria-hidden="true"></i> {t.tabs.tech}</button>
        <button type="button" class="interest-tab" role="tab" aria-selected="false" aria-controls="panel-music" id="interest-music" tabindex="-1" data-interest-tab><i class="fas fa-music" aria-hidden="true"></i> {t.tabs.music}</button>
        <button type="button" class="interest-tab" role="tab" aria-selected="false" aria-controls="panel-aviation" id="interest-aviation" tabindex="-1" data-interest-tab><i class="fas fa-plane" aria-hidden="true"></i> {t.tabs.aviation}</button>
        <button type="button" class="interest-tab" role="tab" aria-selected="false" aria-controls="panel-photo" id="interest-photo" tabindex="-1" data-interest-tab><i class="fas fa-camera" aria-hidden="true"></i> {t.tabs.photo}</button>
      </div>

      <div class="interest-panels">
        <div class="interest-panel is-active" role="tabpanel" id="panel-tech" aria-labelledby="interest-tech" data-interest-panel>
          <p>{t.tech.intro}</p>
          <p>
            {projectParts.map((part) => {
              if (part === 'github') {
                return <a href={profileLinks.github} target="_blank" rel="noopener noreferrer">GitHub</a>;
              }
              if (part === 'yorkDevelopment') {
                return <a href={profileLinks.organizationSite} target="_blank" rel="noopener noreferrer">York Development</a>;
              }
              return part;
            })}
          </p>
          <details class="expand-section">
            <summary class="expand-summary">{t.tech.experience.heading}</summary>
            <div class="expand-body">
              <dl class="expand-list">
                <div class="expand-item"><dt>{t.tech.experience.discordBot[0]}</dt><dd>{t.tech.experience.discordBot[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.experience.ios[0]}</dt><dd>{t.tech.experience.ios[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.experience.web[0]}</dt><dd>{t.tech.experience.web[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.experience.oss[0]}</dt><dd>{t.tech.experience.oss[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.experience.more}</dt></div>
              </dl>
            </div>
          </details>

          <details class="expand-section">
            <summary class="expand-summary">{t.tech.languages.heading}</summary>
            <div class="expand-body">
              <dl class="expand-list">
                <div class="expand-item"><dt>{t.tech.languages.learning[0]}</dt><dd>{t.tech.languages.learning[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.languages.more}</dt></div>
              </dl>
            </div>
          </details>

          <details class="expand-section">
            <summary class="expand-summary">{t.tech.hardware.heading}</summary>
            <div class="expand-body">
              <dl class="expand-list">
                <div class="expand-item"><dt>{t.tech.hardware.hackintosh[0]}</dt><dd>{t.tech.hardware.hackintosh[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.hardware.raspberryPi[0]}</dt><dd>{t.tech.hardware.raspberryPi[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.hardware.maker[0]}</dt><dd>{t.tech.hardware.maker[1]}</dd></div>
                <div class="expand-item"><dt>{t.tech.hardware.more}</dt></div>
              </dl>
            </div>
          </details>
        </div>

        <div class="interest-panel" role="tabpanel" id="panel-music" aria-labelledby="interest-music" data-interest-panel hidden>
          <p>{t.music.daw}</p>
          <p>{t.music.guitar}</p>
          <p>
            <strong>{t.music.recommended}</strong>
            <br>ヨルシカ, n-buna, Avicii, Porter Robinson, Galilei Galileo, tayori, Martin Garrix, RADWIMPS, Dabin, Said the Sky, ILLENIUM, Snail's House, ...
          </p>
          <p class="subtext"><em>{t.music.note}</em></p>
        </div>

        <div class="interest-panel" role="tabpanel" id="panel-aviation" aria-labelledby="interest-aviation" data-interest-panel hidden>
          <p>{t.aviation.intro}</p>
          <p>{t.aviation.airbus}</p>
          <p>
            {aviationParts.map((part) => {
              if (part === 'volanta') {
                return <a href={profileLinks.volanta} target="_blank" rel="noopener noreferrer">{t.aviation.links.volanta}</a>;
              }
              return part;
            })}
          </p>
        </div>

        <div class="interest-panel" role="tabpanel" id="panel-photo" aria-labelledby="interest-photo" data-interest-panel hidden>
          <p>{t.photo.intro}</p>
          <p>{t.photo.craft}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<AboutSectionIsland client:idle />
