---
import LinksSectionIsland from './islands/LinksSectionIsland';
import { profileHandles, profileLinks } from '../data/config';
import type { UiStrings } from '../i18n/ui';

interface Props {
  t: UiStrings['links'];
}

const { t } = Astro.props;
---

<section id="links" class="panel" aria-label={t.label}>
  <div class="links-viewport" aria-live="polite">
    <div class="links-view links-view-main" id="links-main-view" data-links-view="main" aria-label={t.listLabel}>
      <h3 class="section-title" id="links-heading">{t.heading}</h3>
      <section class="link-group" aria-labelledby="links-code">
        <h4 id="links-code" class="link-group-title">{t.code}</h4>
        <ul class="link-list">
          <li>
            <a href={profileLinks.github} class="line-link" target="_blank" rel="noopener noreferrer me">
              <span class="icon" aria-hidden="true"><i class="fab fa-github"></i></span>
              <span class="text-wrap">
                <span class="text">GitHub</span>
                <span class="subtext">{t.githubSubtext}</span>
              </span>
            </a>
          </li>
        </ul>
      </section>
      <section class="link-group" aria-labelledby="links-community">
        <h4 id="links-community" class="link-group-title">{t.community}</h4>
        <ul class="link-list">
          <li>
            <a class="line-link" href={profileLinks.discordProfile} target="_blank" rel="noopener noreferrer" id="discord-link-trigger" data-discord-link>
              <span class="icon" aria-hidden="true"><i class="fab fa-discord"></i></span>
              <span class="text-wrap">
                <span class="text">Discord ({profileHandles.discord})</span>
                <span class="subtext">{t.discordSubtext}</span>
              </span>
            </a>
          </li>
          <li>
            <a class="line-link" href={profileLinks.steamProfile} target="_blank" rel="noopener noreferrer">
              <span class="icon" aria-hidden="true"><i class="fab fa-steam"></i></span>
              <span class="text-wrap">
                <span class="text">Steam</span>
                <span class="subtext">{t.steamSubtext}</span>
              </span>
            </a>
          </li>
        </ul>
      </section>
      <section class="link-group" aria-labelledby="links-music">
        <h4 id="links-music" class="link-group-title">{t.music}</h4>
        <ul class="link-list">
          <li>
            <a class="line-link" href={profileLinks.soundcloud} target="_blank" rel="noopener noreferrer">
              <span class="icon" aria-hidden="true"><i class="fab fa-soundcloud"></i></span>
              <span class="text-wrap">
                <span class="text">SoundCloud</span>
                <span class="subtext">{t.soundcloudSubtext}</span>
              </span>
            </a>
          </li>
          <li>
            <a class="line-link" href={profileLinks.bandcamp} target="_blank" rel="noopener noreferrer">
              <span class="icon" aria-hidden="true"><i class="fab fa-bandcamp"></i></span>
              <span class="text-wrap">
                <span class="text">Bandcamp</span>
                <span class="subtext">{t.bandcampSubtext}</span>
              </span>
            </a>
          </li>
        </ul>
      </section>
      <section class="link-group" aria-labelledby="links-support">
        <h4 id="links-support" class="link-group-title">{t.support}</h4>
        <ul class="link-list">
          <li>
            <a class="line-link" href={profileLinks.buyMeACoffee} target="_blank" rel="noopener noreferrer">
              <span class="icon" aria-hidden="true"><i class="fas fa-coffee"></i></span>
              <span class="text-wrap">
                <span class="text">Buy Me a Coffee</span>
                <span class="subtext">{t.coffeeSubtext}</span>
              </span>
            </a>
          </li>
        </ul>
      </section>
    </div>

    <section class="links-view links-view-discord" id="discord-before-dm-view" data-links-view="discord" aria-labelledby="discord-before-title" hidden>
      <h3 class="section-title" id="discord-before-title">{t.discordWarningHeading}</h3>
      <p class="discord-before-text">{t.discordWarning1}</p>
      <p class="discord-before-text">{t.discordWarning2}</p>
      <p class="discord-before-text">{t.discordWarning3}</p>
      <p class="discord-before-text">{t.alsoRead} <a href="https://nohello.net/" target="_blank" rel="noopener noreferrer">https://nohello.net/</a></p>
      <div class="discord-before-actions">
        <button type="button" class="btn-plain" id="discord-back-btn" data-discord-back><i class="fas fa-arrow-left" aria-hidden="true"></i> {t.back}</button>
        <a href={profileLinks.discordProfile} target="_blank" rel="noopener noreferrer" class="btn-plain btn-arrow" id="discord-profile-btn" data-discord-profile>
          {t.openDiscord} <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</section>

<LinksSectionIsland client:load />
