---
import SiteFooterIsland from './islands/SiteFooterIsland';
import type { UiStrings } from '../i18n/ui';

interface Props {
  t: UiStrings['footer'];
}

const { t } = Astro.props;
---

<footer class="site-footer frame" role="contentinfo">
  <div class="foot-grid">
    <div class="col">
      <p class="mono small">&copy; <span id="year"></span> York Development</p>
    </div>
    <div class="col">
      <p class="small muted">{t.builtWith}</p>
    </div>
    <div class="col align-right">
      <button id="scroll-top" class="btn-plain small" type="button">{t.backToTop}</button>
    </div>
  </div>
</footer>

<SiteFooterIsland client:idle />
