---
import { Image } from 'astro:assets';
import { profile } from '../data/app';
import ProfileHeaderIsland from './islands/ProfileHeaderIsland';
import type { UiStrings } from '../i18n/ui';

interface Props {
  t: UiStrings['header'];
}

const { t } = Astro.props;
---

<header class="site-header frame" role="banner">
  <div class="identity">
    <Image
      class="avatar"
      src={profile.avatarOptimizedSource}
      alt="York"
      width="160"
      height="160"
      decoding="async"
      loading="eager"
      fetchpriority="high"
      densities={[1.5, 2]}
    />
    <div class="name-block">
      <h1 class="primary-name">York</h1>
      <h2 class="secondary-name">york0524 • ヨーク</h2>
      <p class="bio-subtitle" aria-hidden="true">{t.bioLabel}</p>
      <p class="tagline" id="bio">{t.tagline}</p>
      <p class="contact-email">
        <a href={`mailto:${profile.email}`} id="contact-email-link" class="email-link mono" title={t.emailTitle} rel="noopener noreferrer">
          <span class="icon" aria-hidden="true"><i class="fas fa-envelope"></i></span>
          <span class="addr">york<span class="email-honeypot">null</span>@york.qzz.io</span>
        </a>
      </p>
    </div>
  </div>

  <div class="meta-lines" aria-label={t.metadataLabel}>
    <div class="clock-line">
      <span class="label">{t.locationLabel}</span>
      <span class="mono">{t.location}</span>
    </div>
    <div class="clock-line">
      <span class="label">{t.localTime}</span>
      <span id="local-time" class="mono">--:--</span>
    </div>
  </div>
</header>

<ProfileHeaderIsland client:load />
