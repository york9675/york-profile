---
import { Image } from 'astro:assets';
import orgAvatar from '../assets/york-dev-avatar.jpeg';
---

<section id="org" class="panel" aria-labelledby="org-heading">
  <h3 class="section-title" id="org-heading">Organizations</h3>
  <div class="org-wrapper">
    <div class="org-card">
      <Image src={orgAvatar} alt="York Development" class="org-avatar" width={128} height={128} loading="lazy" decoding="async" />
      <div class="org-text">
        <h4 class="org-name">York Development</h4>
        <p class="org-role">Founder / Developer</p>
        <p class="org-desc">We build intuitive, user-friendly applications that make your daily tasks more convenient.</p>
        <div class="org-actions">
          <a href="https://york9675.github.io/website" target="_blank" rel="noopener noreferrer" class="btn-plain btn-arrow" aria-label="Visit York Development site">
            Visit <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
