---
import { Image } from 'astro:assets';
import { profile } from '../data/app';
import { profileLinks } from '../data/config';
import type { UiStrings } from '../i18n/ui';

interface Props {
  t: UiStrings['org'];
}

const { t } = Astro.props;
---

<section id="org" class="panel" aria-labelledby="org-heading">
  <h3 class="section-title" id="org-heading">{t.heading}</h3>
  <div class="org-wrapper">
    <div class="org-card">
      <Image
        src={profile.orgAvatarOptimizedSource}
        alt="York Development"
        class="org-avatar"
        width="128"
        height="128"
        loading="lazy"
        decoding="async"
        fetchpriority="low"
        densities={[1.5, 2]}
      />
      <div class="org-text">
        <h4 class="org-name">York Development</h4>
        <p class="org-role">{t.role}</p>
        <p class="org-desc">{t.description}</p>
        <div class="org-actions">
          <a href={profileLinks.organizationSite} target="_blank" rel="noopener noreferrer" class="btn-plain btn-arrow" aria-label={t.visitLabel}>
            {t.visit} <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
