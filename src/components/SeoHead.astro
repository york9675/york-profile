---
import { profile } from '../data/app';
import { defaultLocale, getLocaleUrl, locales } from '../i18n/ui';
import type { Locale, UiStrings } from '../i18n/ui';

interface Props {
  locale: Locale;
  t: UiStrings;
}

const { locale, t } = Astro.props;
const canonicalUrl = `${profile.siteUrl}${getLocaleUrl(locale)}`;
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': canonicalUrl,
  name: profile.name,
  alternateName: profile.handle,
  url: canonicalUrl,
  image: profile.avatar,
  description: t.meta.description,
  jobTitle: t.org.role,
  homeLocation: {
    '@type': 'Place',
    name: t.header.location
  },
  sameAs: [
    'https://github.com/york9675',
    'https://www.last.fm/user/york0524',
    'https://soundcloud.com/york0524'
  ]
};
---

<meta name="msapplication-TileColor" content="#000000" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
<meta name="color-scheme" content="light dark" />
<link rel="icon" href={profile.avatar} />
<link rel="dns-prefetch" href="https://avatars.githubusercontent.com" />
<link rel="preconnect" href="https://avatars.githubusercontent.com" />
<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" crossorigin="anonymous" referrerpolicy="no-referrer" />

<meta property="og:type" content="profile" />
<meta property="og:locale" content={t.meta.ogLocale} />
<meta property="og:title" content="York • york0524" />
<meta property="og:description" content={t.meta.description} />
<meta property="og:image" content={profile.avatar} />
<meta property="og:image:alt" content={t.meta.avatarAlt} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={t.meta.siteName} />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="York • york0524" />
<meta name="twitter:description" content={t.meta.description} />
<meta name="twitter:image" content={profile.avatar} />
<meta name="twitter:creator" content="@york0524" />
<meta name="twitter:site" content="@york0524" />
<link rel="canonical" href={canonicalUrl} />
{locales.map((item) => (
  <link rel="alternate" hreflang={item} href={`${profile.siteUrl}${getLocaleUrl(item)}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${profile.siteUrl}${getLocaleUrl(defaultLocale)}`} />

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />

<script is:inline>
  try {
    const theme = localStorage.getItem('themeMode');
    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    } else if (theme === 'newspaper') {
      document.documentElement.setAttribute('data-theme', 'newspaper');
    } else if (theme === 'system') {
      if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    }
  } catch (error) {
    console.warn('Could not load theme preference:', error);
  }
</script>
